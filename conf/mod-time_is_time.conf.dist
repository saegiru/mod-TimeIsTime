#####################################################################################################
[worldserver]

# Announce
#####################################################################################################
# Announce  TimeIsTime
# Settings: 0 = off, 1 = on
# Default:  1
# Example:  TimeIsTime.Announce = 1
#####################################################################################################
TimeIsTime.Announce = 1

# Enable
#####################################################################################################
# Enable TimeIsTime
# Settings: 0 = off, 1 = on
# Default:  1
# Example:  TimeIsTime.Enable = 1
#####################################################################################################
TimeIsTime.Enable = 1

# SpeedRate
#####################################################################################################
# Adjust the number of game days per real day by altering the Realm Timer
# Settings: 60 is 1 second (Real Time) = 1 minute (Realm Timer)
#
#           Accepted range: 0.01 to 240.0
#           Invalid values are clamped and logged.
#
#           60.0  = 1 Game Day every 24   minutes
#           30.0  = 1 Game Day every 48   minutes
#           15.0  = 1 Game Day every 96   minutes or 1.6  Hours
#           7.5   = 1 Game Day every 192  minutes or 3.2  Hours
#           3.75  = 1 Game Day every 384  minutes or 6.4  Hours
#           1.875 = 1 Game Day every 768  minutes or 12.8 Hours
#           1.0   = 1 Game Day every 1440 minutes or 24.0 Hours
# Default:  1.0 (Blizzlike)
# Example:  TimeIsTime.SpeedRate = 1.0
#####################################################################################################
TimeIsTime.SpeedRate = 1.0

# TimeStart and HourOffset:
#####################################################################################################
# TimeStart is an optional non-negative Unix timestamp used as the realm-wide clock phase anchor.
# At TimeStart, the displayed clock uses TimeStart's time of day. The clock then advances at
# SpeedRate. Leave it at 0 to use Unix epoch time. This keeps the cycle continuous across restarts.
#
# HourOffset adds or subtracts hours from the virtual clock.
# Accepted range: -24.0 to 24.0. Invalid values are clamped and logged.
#
# Default:  0 (Unix epoch phase)
# Example:  Based on the settings below, the GMT TimeStart and HourOffset would be:
#           TimeIsTime.TimeStart = 1213963200
#           TimeIsTime.HourOffset = 5
#           City: Chicago, IL USA
#           Summer Solstice Date   :: 06-20-2008
#           Sunrise  = 05:15:27    :: 1213938927
#           Sunset   = 20:29:01    :: 1213993741
#           Midday   = 12:00:00    :: 1213963200
#           Midnight = 24:00:00    :: 1213920000
#####################################################################################################
TimeIsTime.TimeStart = 0
TimeIsTime.HourOffset = 0.0
